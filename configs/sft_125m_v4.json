{
  "run_name": "sft-v4-curriculum-small-from-130k",
  "out_dir": "runs/sft-v4-curriculum-small-from-130k",
  "init_checkpoint": "runs/gpt3-small-125m/step_130000.pt",
  "seed": 20260512,
  "device": "auto",
  "dtype": "bfloat16",
  "compile": false,
  "model": {
    "vocab_size": 50000,
    "context_length": 1024,
    "d_model": 768,
    "num_layers": 12,
    "num_heads": 12,
    "d_ff": 2048,
    "dropout": 0.0
  },
  "data": {
    "train_path": "data/sft/v4/train.jsonl",
