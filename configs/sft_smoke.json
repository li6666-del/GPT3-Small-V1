{
  "run_name": "sft-smoke",
  "out_dir": "runs/sft-smoke",
  "init_checkpoint": null,
  "seed": 1337,
  "device": "auto",
  "dtype": "float32",
  "compile": false,
  "model": {
    "vocab_size": 256,
    "context_length": 32,
    "d_model": 64,
    "num_layers": 2,
    "num_heads": 4,
    "d_ff": 128,
    "dropout": 0.0
  },
  "data": {
    "train_path": "data/sft_toy/train.jsonl",
    "valid_path": "data/sft_toy/valid.jsonl",
    "ids_only": true,
    "pad_token_id": 0,
    "batch_size": 4,
    "train_eot": true,
    "truncate": true
  },
  "optim": {
    "learning_rate": 0.0006,
    "min_lr": 0.00006,
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.95,
    "grad_clip": 1.0
  },
  "train": {
    "max_steps": 10,
    "warmup_steps": 2,
    "gradient_accumulation_steps": 2,
    "log_interval": 1,
    "eval_interval": 5,
    "eval_iters": 4,
    "save_interval": 5,
    "resume": false
  }
}
