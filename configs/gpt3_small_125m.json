{
  "run_name": "gpt3-small-125m",
  "out_dir": "runs/gpt3-small-125m",
  "seed": 1337,
  "device": "auto",
  "dtype": "bfloat16",
  "compile": true,
  "model": {
    "vocab_size": 50000,
    "context_length": 1024,
    "d_model": 768,
    "num_layers": 12,
    "num_heads": 12,
    "d_ff": 2048,
    "dropout": 0.0
  },
  "data": {
    "train_path": "data/tokens/train.bin",
    "valid_path": "data/tokens/valid.bin",
    "dtype": "uint16",
    "batch_size": 8,
    "num_workers": 2
  },
  "optim": {
    "learning_rate": 0.0003,
    "min_lr": 0.00003,
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.95,
    "grad_clip": 1.0
  },
  "train": {
    "max_steps": 100000,
    "warmup_steps": 2000,
    "gradient_accumulation_steps": 8,
    "log_interval": 10,
    "eval_interval": 500,
    "eval_iters": 100,
    "save_interval": 5000,
    "resume": true
  }
}
